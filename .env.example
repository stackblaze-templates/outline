# Copy this file to .env and fill in the values before running locally.
# NEVER commit .env with real secrets.

# Generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-long-random-hex-string

# Generate with: openssl rand -hex 32
UTILS_SECRET=replace-with-another-long-random-hex-string

# Password for the local PostgreSQL container
POSTGRES_PASSWORD=replace-with-a-strong-password

# Public URL of the Outline instance
URL=http://localhost:3000
